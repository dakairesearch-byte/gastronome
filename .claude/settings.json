{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git fetch *)",

      "Bash(git worktree list*)",
      "Bash(git worktree add ../food-review-* *)",
      "Bash(git diff --name-only*)",
      "Bash(git log --since=* --name-only*)",
      "Bash(git log --since=* --oneline*)",

      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",

      "Bash(wc -l*)",

      "Bash(psql *-c *SELECT*)",
      "Bash(psql *--command*SELECT*)",
      "Bash(sqlite3 *)",

      "mcp__supabase__list_tables",
      "mcp__supabase__list_migrations",
      "mcp__supabase__execute_sql",
      "mcp__supabase__get_logs",
      "mcp__supabase__get_advisors",

      "mcp__a124b4b5-205c-4ebf-9089-553597590855__list_edge_functions",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__get_edge_function",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__list_extensions",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__list_branches",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__generate_typescript_types",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__get_logs",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__get_advisors",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__get_project_url"
    ],
    "deny": [
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__apply_migration",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__deploy_edge_function",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__create_branch",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__delete_branch",
      "mcp__a124b4b5-205c-4ebf-9089-553597590855__merge_branch",

      "Bash(*gh pr merge*)",
      "Bash(*gh pr ready*)",
      "Bash(*gh pr close*)",
      "Bash(*rm -rf*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/sql-guard.sh"
          }
        ]
      },
      {
        "matcher": "mcp__a124b4b5-205c-4ebf-9089-553597590855__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/sql-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/branch-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/gh-pr-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/write-guard.sh"
          }
        ]
      }
    ]
  }
}
