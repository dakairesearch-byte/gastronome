# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# supabase
supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local

# mcp config (session-specific tokens)
.mcp.json

# one-off scrape/debug scratch scripts (sandbox-only, not production)
/scripts/debug*.ts
/scripts/testScrapeChips.ts

# working dirs from pipeline scripts (logs, watchdog shards, tmp artifacts)
/logs/
/tmp/

# generated run reports and stray logs (keep out of version control)
*-report-*.json
*.log
