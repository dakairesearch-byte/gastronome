# .env.example — Vercel deploy-time variables
#
# Copy this file to .env.local for local development.
# In Vercel: add each variable under Project Settings > Environment Variables.
# Never commit .env.local or any file containing real secrets.

# ---------------------------------------------------------------------------
# Supabase — required for all environments
# ---------------------------------------------------------------------------

# Public URL of the Supabase project (safe to expose to the browser)
# Required | Client + Server
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon key (safe to expose; Row Level Security enforces access)
# Required | Client + Server
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service-role key — bypasses RLS; NEVER ship to the browser
# Required (scripts only — data pipeline scripts in scripts/)
# Do NOT set this in NEXT_PUBLIC_* — server-side / CI only
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ---------------------------------------------------------------------------
# Google Places — required for restaurant enrichment and autocomplete
# ---------------------------------------------------------------------------

# Server-side Google Places (New) API key — used in enrichment pipeline
# Required | Server only (scripts/enrichWithGooglePlaces.ts, API routes)
GOOGLE_PLACES_API_KEY=<your-server-side-places-key>

# Client-side Google Places key — used for address autocomplete in the browser
# Required | Client (NEXT_PUBLIC_ prefix exposes it to the browser)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=<your-client-side-places-key>

# Client-side Google Maps Embed API key — powers the embedded map iframe on
# restaurant detail pages. Restrict it to the Maps Embed API + your domain.
# Optional | Client (map block is hidden when unset)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=<your-maps-embed-key>

# Client-side Google Maps JavaScript API key — powers the interactive
# split-pane map on /discover. The *Maps JavaScript API* must be enabled on
# this key (it is a SEPARATE product from the Places API and Maps Embed API).
# Restrict it to the Maps JavaScript API + your domain. If unset, the loader
# falls back to NEXT_PUBLIC_GOOGLE_PLACES_API_KEY; if that is also unset (or
# the JS API fails to load) the Discover map degrades to a StaticMapTile.
# Optional | Client (interactive map degrades to StaticMapTile when unset)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<your-maps-javascript-key>

# ---------------------------------------------------------------------------
# Site / SEO
# ---------------------------------------------------------------------------

# Canonical public origin (no trailing slash). Drives metadataBase for
# absolute OG/Twitter image URLs, plus sitemap.xml and robots.txt loc/sitemap
# values. Defaults to http://localhost:3000 when unset.
# Required (production) | Client + Server
NEXT_PUBLIC_SITE_URL=https://gastronome.app

# ---------------------------------------------------------------------------
# Admin / monitoring
# ---------------------------------------------------------------------------

# Comma-separated list of Supabase auth user IDs (UUIDs) granted admin access.
# Used server-side to gate /admin routes; never expose with NEXT_PUBLIC_.
# Optional | Server only
ADMIN_USER_IDS=<uuid-1>,<uuid-2>

# Sentry DSN for error + performance monitoring. Leave unset to disable
# Sentry reporting entirely (no-op when empty).
# Optional | Server (+ Client if a NEXT_PUBLIC_SENTRY_DSN mirror is added)
SENTRY_DSN=<your-sentry-dsn>
